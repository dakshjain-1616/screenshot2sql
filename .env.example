# Screenshot2SQL — Environment Variables
# Copy this file to .env and fill in your values

# ── OpenRouter API ────────────────────────────────────────────────────────────

# OpenRouter API key for vision analysis (uses google/gemini-2.0-flash by default).
# Get one at: https://openrouter.ai/keys
# If not set, the app runs in demo/mock mode with pre-built schemas.
OPENROUTER_API_KEY=

# Vision model used for screenshot analysis.
# Default: google/gemini-2.5-flash-lite (fast, cheap, 1M context, excellent vision)
# Alternatives: google/gemini-2.5-flash, meta-llama/llama-4-scout, qwen/qwen2.5-vl-72b-instruct
SCREENSHOT_MODEL=google/gemini-2.5-flash-lite

# OpenRouter API base URL (change only if using a compatible proxy).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Maximum tokens in the model response.
# Default: 4096
MAX_TOKENS=4096

# Max API retries on transient errors (rate limits, 503s, timeouts).
# Default: 3
MAX_RETRIES=3

# Base delay in seconds between retries — doubles each attempt (exponential backoff).
# Default: 2.0
RETRY_DELAY=2.0

# ── CLI ───────────────────────────────────────────────────────────────────────

# Default output format for the CLI.
# Options: sql | json | mermaid | sqlalchemy | all
# Default: sql
OUTPUT_FORMAT=sql

# ── Analysis Quality ──────────────────────────────────────────────────────────

# Minimum confidence score (0.0–1.0) required to output a schema.
# If confidence < threshold/2, exit with error; if between, warn and continue.
# Default: 0.0 (no threshold — always produce output)
CONFIDENCE_THRESHOLD=0.0

# Automatically append CREATE INDEX recommendations to SQL output.
# Default: false
SHOW_INDEXES=false

# ── Streamlit ─────────────────────────────────────────────────────────────────

# Port for the Streamlit web app.
# Default: 8501
STREAMLIT_SERVER_PORT=8501

# Bind address for the Streamlit web app.
# Default: localhost
STREAMLIT_SERVER_ADDRESS=localhost
